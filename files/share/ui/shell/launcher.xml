<component>
  <view extends="lv_obj" name="launcher_root" width="100%" height="100%"
        flex_flow="column" scrollable="false" style_bg_color="#f4f7fb"
        style_bg_opa="100%" style_pad_left="10" style_pad_right="10"
        style_pad_top="8" style_pad_bottom="5" style_pad_row="4">
    <!-- Compatibility names remain present, but Home follows a phone layout:
         no desktop title, help banner, or previous/next arrow controls. -->
    <lv_obj name="launcher_header" width="100%" height="0" hidden="true"
            scrollable="false" style_bg_opa="0%" style_border_width="0"
            style_pad_all="0">
      <lv_obj name="launcher_title_row" width="100%" height="0" hidden="true">
        <lv_label name="launcher_title" text="应用" hidden="true"/>
        <lv_obj name="page_navigation" width="0" height="0" hidden="true">
          <lv_button name="page_previous" width="1" height="1" hidden="true"/>
          <lv_label name="page_label" text="●" hidden="true"/>
          <lv_button name="page_next" width="1" height="1" hidden="true"/>
        </lv_obj>
      </lv_obj>
      <lv_label name="launcher_hint" text="" hidden="true"/>
    </lv_obj>
    <lv_obj name="app_grid" width="100%" height="1" flex_grow="1"
            flex_flow="row_wrap" scrollable="false" style_bg_opa="0%"
            style_border_width="0" style_pad_all="2" style_pad_row="8"
            style_pad_column="8"/>
    <lv_label name="launcher_status" text="●" width="100%" height="18"
              long_mode="dot" style_text_font="msys_12"
              style_text_color="#6e7890" align="center"/>
    <lv_button name="launcher_edit_done" width="58" height="32"
               align="top_right" x="-3" y="3" floating="true" hidden="true"
               style_radius="16" style_bg_color="#ffffff"
               style_bg_opa="88%" style_shadow_width="0"
               style_border_width="1" style_border_color="#d7deea">
      <lv_label name="launcher_edit_done_label" text="完成" align="center"
                style_text_font="msys_14" style_text_color="#3159c9"/>
      <lv_event-call-function trigger="clicked" callback="shell_action"
                              user_data="launcher-edit-done"/>
    </lv_button>
  </view>
</component>
